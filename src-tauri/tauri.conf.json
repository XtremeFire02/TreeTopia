{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TreeTopia",
  "version": "1.0.0",
  "identifier": "com.treetopia.game",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run start"
  },
  "app": {
    "windows": [
      {
        "title": "TreeTopia",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
